# Local Server
PORT=8081
HOST=0.0.0.0

# Global Server (set this on the local server to sync from global)
# UPSTREAM_URL=http://your-global-server:8080

# Control endpoint authentication (optional but recommended)
# CONTROL_TOKEN=your-secret-token-here

# Video generation
# COUNT=80
# DURATION_SECONDS=180
# FPS=30
# CONCURRENCY=4
# X264_PRESET=veryfast
# CRF=20
