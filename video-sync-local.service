[Unit]
Description=Video Sync Local Server
After=network.target video-sync-global.service

[Service]
Type=simple
User=node
WorkingDirectory=/opt/video-sync
ExecStart=/usr/bin/node server-local.js
Restart=on-failure
RestartSec=5
Environment=PORT=8081
Environment=HOST=0.0.0.0
Environment=UPSTREAM_URL=http://localhost:8080
Environment=CONTROL_TOKEN=

[Install]
WantedBy=multi-user.target
